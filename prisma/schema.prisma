// Apex Mídias — admin database schema
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectCategory {
  BRAND
  FASHION
  SHORT_FILM
  COMMERCIAL
  MUSIC
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaAspect {
  WIDE
  TALL
  SQUARE
}

enum MediaSlot {
  COVER
  HERO
  GALLERY
}

enum ContactProjectType {
  BRAND
  COMMERCIAL
  FASHION
  MUSIC
  DOCUMENTARY
  OTHER
}

enum ContactStatus {
  NEW
  CONTACTED
  QUALIFIED
  ARCHIVED
}

model Project {
  id        String          @id @default(cuid())
  slug      String          @unique
  title     String
  client    String
  year      Int
  category  ProjectCategory
  excerpt   String
  brief     String
  featured         Boolean         @default(false)
  featuredOnAbout  Boolean         @default(false)
  order            Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  media   ProjectMedia[]
  credits ProjectCredit[]

  @@index([category])
  @@index([featured])
  @@index([featuredOnAbout])
}

model ProjectMedia {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slot      MediaSlot
  type      MediaType
  src       String
  poster    String?
  caption   String?
  width     Int
  height    Int
  aspect    MediaAspect?
  order     Int          @default(0)

  @@index([projectId])
}

model ProjectCredit {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String
  name      String
  order     Int     @default(0)

  @@index([projectId])
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  logo      String
  width     Int
  height    Int
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id          String             @id @default(cuid())
  name        String
  email       String
  company     String?
  projectType ContactProjectType
  message     String

  status    ContactStatus @default(NEW)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  gclid       String?
  fbclid      String?
  msclkid     String?
  ttclid      String?
  referrer    String?
  landingPage String?
  userAgent   String?

  @@index([status, createdAt])
  @@index([utmCampaign])
}
