# ──────────────────────────────────────────────────────────────────────────
# Database — Neon Postgres (https://neon.tech)
# Use the POOLED connection string for runtime (works in Edge/serverless).
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"

# ──────────────────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
# ──────────────────────────────────────────────────────────────────────────
AUTH_SECRET=""

# Single admin user (no signup; credentials are validated against env)
ADMIN_EMAIL="admin@apexmidias.com"
# bcrypt hash. Generate with: npx tsx -e "import bcrypt from 'bcryptjs'; console.log(bcrypt.hashSync(process.argv[1], 10))" 'your-password'
ADMIN_PASSWORD_HASH=""

# ──────────────────────────────────────────────────────────────────────────
# UploadThing (https://uploadthing.com)
# ──────────────────────────────────────────────────────────────────────────
UPLOADTHING_TOKEN=""
