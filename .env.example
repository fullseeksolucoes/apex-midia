# ──────────────────────────────────────────────────────────────────────────
# Database — Neon Postgres (https://neon.tech)
# Use the POOLED connection string for runtime (works in Edge/serverless).
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"

# ──────────────────────────────────────────────────────────────────────────
# Clerk (https://dashboard.clerk.com) — copy from API Keys page
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Optional overrides (defaults already point to /admin/*)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/admin/login"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/admin/dashboard"

# ──────────────────────────────────────────────────────────────────────────
# UploadThing (https://uploadthing.com)
# ──────────────────────────────────────────────────────────────────────────
UPLOADTHING_TOKEN=""
